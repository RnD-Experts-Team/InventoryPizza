{
  "info": {
    "name": "Inventory API",
    "_postman_id": "inventory-api-v2",
    "description": "Complete collection for the Laravel Inventory Service.\n\n**Setup:**\n1. Set `base_url` collection variable (default: `http://localhost:8000/api`).\n2. Run **Login** — the token is auto-saved to `token`.\n3. Run **Create Unit** and **Create Item** first — their IDs are auto-saved and used by later requests.\n4. Run **Generate Link** — `link_token` is auto-saved for the public endpoints.\n\n**Roles:**\n- `inventory_specialist` — units, items, generate links, view entries.\n- `store_manager` — generate links, view entries, edit entry item counts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:8000/api", "type": "string" },
    { "key": "token",          "value": "",  "type": "string" },
    { "key": "unit_id",        "value": "1", "type": "string" },
    { "key": "item_id",        "value": "1", "type": "string" },
    { "key": "link_id",        "value": "1", "type": "string" },
    { "key": "link_token",     "value": "",  "type": "string" },
    { "key": "entry_id",       "value": "1", "type": "string" },
    { "key": "entry_item_id",  "value": "1", "type": "string" },
    { "key": "store_id",       "value": "STORE-ALPHA", "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Returns a Sanctum bearer token. Saved automatically to the `token` variable."
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Returns the authenticated user's id, name, email and role."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Deletes the current Sanctum token. Returns 204."
          }
        }
      ]
    },

    {
      "name": "Units  [inventory_specialist]",
      "item": [
        {
          "name": "Get All Units",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/units",
              "host": ["{{base_url}}"],
              "path": ["inventory", "units"]
            }
          }
        },
        {
          "name": "Create Unit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('unit_id', String(json.data.id));",
                  "    console.log('unit_id saved:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kilogram\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/inventory/units",
              "host": ["{{base_url}}"],
              "path": ["inventory", "units"]
            },
            "description": "Creates a unit. `name` must be unique. ID auto-saved to `unit_id`."
          }
        },
        {
          "name": "Update Unit",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kilogram (kg)\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/inventory/units/{{unit_id}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "units", "{{unit_id}}"]
            }
          }
        },
        {
          "name": "Delete Unit",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/units/{{unit_id}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "units", "{{unit_id}}"]
            },
            "description": "Returns 204 No Content."
          }
        }
      ]
    },

    {
      "name": "Items  [inventory_specialist]",
      "item": [
        {
          "name": "Get All Items",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/items",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items"]
            }
          }
        },
        {
          "name": "Get Item by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/items/{{item_id}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items", "{{item_id}}"]
            }
          }
        },
        {
          "name": "Create Item (JSON — no image)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('item_id', String(json.data.id));",
                  "    console.log('item_id saved:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ultimatrix_id\": \"ITM-001\",\n  \"name_en\": \"Rice\",\n  \"name_ar\": \"أرز\",\n  \"name_es\": \"Arroz\",\n  \"details_en\": \"Long grain white rice\",\n  \"details_ar\": null,\n  \"details_es\": null,\n  \"unit_1_id\": {{unit_id}},\n  \"unit_2_id\": 2,\n  \"unit_2_per_unit_1\": 1000,\n  \"unit_3_id\": null,\n  \"unit_3_per_unit_2\": null,\n  \"types\": [\"daily\", \"weekly\"],\n  \"all_stores\": true,\n  \"store_ids\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/inventory/items",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items"]
            },
            "description": "Create an item without an image.\n\n`unit_1_id` = primary unit (e.g. kg), `unit_2_id` = secondary unit (e.g. gram), `unit_2_per_unit_1` = conversion factor.\nSet `all_stores: true` to link to all stores, or `all_stores: false` + `store_ids: [\"STORE-ALPHA\"]` for specific stores.\n`types` accepted values: `daily`, `weekly`, `period`."
          }
        },
        {
          "name": "Create Item (form-data — with image)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "ultimatrix_id",     "value": "ITM-002",  "type": "text" },
                { "key": "name_en",           "value": "Sugar",    "type": "text" },
                { "key": "name_ar",           "value": "سكر",      "type": "text" },
                { "key": "name_es",           "value": "Azúcar",   "type": "text" },
                { "key": "details_en",        "value": "",         "type": "text" },
                { "key": "unit_1_id",         "value": "{{unit_id}}", "type": "text" },
                { "key": "unit_2_id",         "value": "2",        "type": "text" },
                { "key": "unit_2_per_unit_1", "value": "1000",     "type": "text" },
                { "key": "types[0]",          "value": "daily",    "type": "text" },
                { "key": "all_stores",        "value": "true",     "type": "text" },
                { "key": "image",             "type": "file",      "src": "", "description": "JPG/JPEG/PNG, max 2 MB" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/inventory/items",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items"]
            },
            "description": "Same as the JSON version but sends multipart/form-data so you can attach an image. Select the file in the `image` row (JPG/JPEG/PNG, max 2 MB)."
          }
        },
        {
          "name": "Update Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ultimatrix_id\": \"ITM-001\",\n  \"name_en\": \"Basmati Rice\",\n  \"name_ar\": \"أرز بسمتي\",\n  \"name_es\": \"Arroz Basmati\",\n  \"details_en\": \"Premium long grain\",\n  \"details_ar\": null,\n  \"details_es\": null,\n  \"unit_1_id\": {{unit_id}},\n  \"unit_2_id\": 2,\n  \"unit_2_per_unit_1\": 1000,\n  \"unit_3_id\": null,\n  \"unit_3_per_unit_2\": null,\n  \"types\": [\"daily\"],\n  \"all_stores\": false,\n  \"store_ids\": [\"{{store_id}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/inventory/items/{{item_id}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items", "{{item_id}}"]
            }
          }
        },
        {
          "name": "Delete Item",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/items/{{item_id}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items", "{{item_id}}"]
            },
            "description": "Returns 204 No Content."
          }
        }
      ]
    },

    {
      "name": "Inventory Links  [inventory_specialist or store_manager]",
      "item": [
        {
          "name": "Get All Links",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/links",
              "host": ["{{base_url}}"],
              "path": ["inventory", "links"]
            },
            "description": "Returns all generated links. `status` is `active` (open) or `submitted` (closed, link expired)."
          }
        },
        {
          "name": "Get Link by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/links/{{link_id}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "links", "{{link_id}}"]
            }
          }
        },
        {
          "name": "Generate Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "    if (json.data.id)    pm.collectionVariables.set('link_id', String(json.data.id));",
                  "    if (json.data.token) pm.collectionVariables.set('link_token', json.data.token);",
                  "    console.log('link_token saved:', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_name\": \"Counter Bob\",\n  \"store_id\": \"{{store_id}}\",\n  \"date\": \"2026-06-24\",\n  \"type\": \"daily\",\n  \"item_ids\": [{{item_id}}]\n}"
            },
            "url": {
              "raw": "{{base_url}}/inventory/links",
              "host": ["{{base_url}}"],
              "path": ["inventory", "links"]
            },
            "description": "Creates a unique public link for a counter. `type` can be `daily`, `weekly`, or `period`. `link_id` and `link_token` are auto-saved."
          }
        }
      ]
    },

    {
      "name": "Public Inventory  (no auth required)",
      "item": [
        {
          "name": "View Public Link",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/public/inventory/{{link_token}}",
              "host": ["{{base_url}}"],
              "path": ["public", "inventory", "{{link_token}}"]
            },
            "description": "Load the form data for a given link token. No authentication needed.\n- 200 — returns store, items, and their units\n- 404 — token not found\n- 410 — link was already submitted"
          }
        },
        {
          "name": "Submit Public Link",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"item_id\": {{item_id}},\n      \"count_unit_1\": 45,\n      \"count_unit_2\": 500,\n      \"count_unit_3\": null\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/public/inventory/{{link_token}}/submit",
              "host": ["{{base_url}}"],
              "path": ["public", "inventory", "{{link_token}}", "submit"]
            },
            "description": "Submit inventory counts. The link closes immediately on success.\n- 201 — returns `reference` and `submitted_at`\n- 404 — token not found\n- 410 — already submitted\n- 422 — item_id does not belong to this link\n\nAll item_ids in the payload must belong to the link."
          }
        }
      ]
    },

    {
      "name": "Entries  [inventory_specialist or store_manager]",
      "item": [
        {
          "name": "Get All Entries",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/entries",
              "host": ["{{base_url}}"],
              "path": ["inventory", "entries"]
            }
          }
        },
        {
          "name": "Get Entry by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.items && json.data.items.length > 0) {",
                  "    pm.collectionVariables.set('entry_item_id', String(json.data.items[0].id));",
                  "    console.log('entry_item_id saved:', json.data.items[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/entries/{{entry_id}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "entries", "{{entry_id}}"]
            },
            "description": "Returns the entry with all items and their full edit history. The first item's ID is auto-saved to `entry_item_id`."
          }
        }
      ]
    },

    {
      "name": "Entry Items  [store_manager]",
      "item": [
        {
          "name": "Edit Entry Item Counts",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"count_unit_1\": 42,\n  \"count_unit_2\": 420,\n  \"count_unit_3\": null,\n  \"reason\": \"Corrected after physical recount\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/inventory/entry-items/{{entry_item_id}}",
              "host": ["{{base_url}}"],
              "path": ["inventory", "entry-items", "{{entry_item_id}}"]
            },
            "description": "Adjusts a submitted count. Every change is permanently logged.\n- `count_unit_3` is nullable (only if the item has a third unit).\n- `reason` is required (min 5 chars, max 1000).\n- Only accessible to `store_manager` role."
          }
        }
      ]
    }

  ]
}
